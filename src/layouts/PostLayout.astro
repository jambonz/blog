---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  updatedDate?: Date;
  description?: string;
  author?: string;
  tags?: string[];
  coverImage?: ImageMetadata;
  canonicalUrl?: string;
}

const { title, date, updatedDate, description, author, tags = [], coverImage, canonicalUrl } =
  Astro.props;

// Dates in frontmatter are date-only; coerced to UTC midnight. Format in UTC so
// they don't drift a day backward for readers/builders behind UTC.
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonicalUrl}
  ogImage={coverImage?.src}
>
  <article class="post">
    <header>
      <h1>{title}</h1>
      <p class="meta">
        {author && <span class="author">{author}</span>}
        <time datetime={date.toISOString()}>{fmt(date)}</time>
        {updatedDate && <span class="updated">(updated {fmt(updatedDate)})</span>}
      </p>
      {tags.length > 0 && (
        <ul class="tags">
          {tags.map((tag) => <li>{tag}</li>)}
        </ul>
      )}
    </header>
    {coverImage && (
      <Image class="cover" src={coverImage} alt={title} widths={[480, 800, 1200]} sizes="(max-width: 70ch) 100vw, 70ch" loading="eager" />
    )}
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    max-width: var(--measure);
    margin: 0 auto;
  }

  header {
    margin-bottom: var(--space-lg);
  }

  h1 {
    font-size: 2rem;
    font-weight: 600;
    line-height: 1.2;
    margin: 0 0 var(--space-sm);
    letter-spacing: -0.02em;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    align-items: baseline;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: 0;
  }

  .meta .author {
    font-weight: 600;
    color: var(--color-text);
  }

  .meta .author::after {
    content: '·';
    margin-left: var(--space-sm);
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    list-style: none;
    padding: 0;
    margin: var(--space-md) 0 0;
  }

  .tags li {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.1rem 0.6rem;
  }

  .cover {
    width: 100%;
    height: auto;
    border-radius: 8px;
    margin-bottom: var(--space-xl);
    border: 1px solid var(--color-border);
  }

  .prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.3;
    margin: var(--space-xl) 0 var(--space-md);
    letter-spacing: -0.01em;
  }

  .prose :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.4;
    margin: var(--space-lg) 0 var(--space-md);
  }

  .prose :global(h4) {
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.4;
    margin: var(--space-lg) 0 var(--space-sm);
  }

  .prose :global(h5) {
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.4;
    margin: var(--space-lg) 0 var(--space-sm);
    color: var(--color-text-muted);
  }

  .prose :global(p) {
    margin: 0 0 var(--space-md);
  }

  .prose :global(a) {
    color: var(--color-link);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(a:hover) {
    text-decoration: none;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 var(--space-md);
    padding-left: var(--space-lg);
  }

  .prose :global(li) {
    margin-bottom: var(--space-xs);
  }

  .prose :global(blockquote) {
    margin: var(--space-md) 0;
    padding-left: var(--space-md);
    border-left: 3px solid var(--color-border);
    color: var(--color-text-muted);
  }

  /* Inline code */
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background-color: var(--color-code-bg);
    padding: 0.15em 0.35em;
    border-radius: 4px;
  }

  /* Code blocks - reset inline styles */
  .prose :global(pre) {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.6;
    margin: var(--space-lg) 0;
    padding: var(--space-md);
    border-radius: 8px;
    overflow-x: auto;
    background-color: var(--color-code-bg) !important;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-xl) 0;
  }

  .prose :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }

  /* display:block + overflow-x lets wide tables scroll inside the content
     column instead of widening the whole page on narrow screens. */
  .prose :global(table) {
    display: block;
    width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
    margin: var(--space-md) 0;
    font-size: 0.875rem;
  }

  .prose :global(th),
  .prose :global(td) {
    padding: var(--space-sm);
    border: 1px solid var(--color-border);
    text-align: left;
  }

  .prose :global(th) {
    font-weight: 600;
    background-color: var(--color-code-bg);
  }
</style>
