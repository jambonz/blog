---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../utils/url';
import { getPosts } from '../utils/posts';

const posts = await getPosts();
---

<BaseLayout title="jambonz blog" description="Engineering notes and product updates from the jambonz team.">
  <main class="index">
    <h1>Blog</h1>
    <ul class="posts">
      {posts.map((post) => {
        const formattedDate = post.data.date.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
          timeZone: 'UTC',
        });
        return (
          <li>
            <a class="card" href={url(post.id)}>
              {post.data.coverImage && (
                <Image class="thumb" src={post.data.coverImage} alt="" widths={[240, 480]} sizes="120px" loading="lazy" />
              )}
              <div class="body">
                <span class="title">{post.data.title}</span>
                {post.data.description && <p class="description">{post.data.description}</p>}
                <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  </main>
</BaseLayout>

<style>
  .index {
    max-width: var(--measure);
    margin: 0 auto;
  }

  h1 {
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-xl);
  }

  .posts {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .posts li {
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .posts li:first-child {
    padding-top: 0;
  }

  .card {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
    text-decoration: none;
    color: inherit;
  }

  .thumb {
    flex: 0 0 120px;
    width: 120px;
    height: 80px;
    object-fit: cover;
    border-radius: 6px;
    border: 1px solid var(--color-border);
  }

  .body {
    min-width: 0;
  }

  .card:hover .title {
    color: var(--color-link);
  }

  .title {
    display: block;
    font-weight: 600;
    font-size: 1.05rem;
    transition: color 0.15s;
  }

  time {
    color: var(--color-text-muted);
    font-size: 0.8125rem;
  }

  .description {
    margin: var(--space-xs) 0;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    line-height: 1.5;
  }
</style>
